# Puerto de acceso a la aplicación (host)
APP_PORT=8085

# Contraseña root MySQL (solo interna, no expuesta)
MYSQL_ROOT_PASSWORD=RootPass_Cambia1!

# Contraseña del usuario de aplicación
MYSQL_APP_PASSWORD=CambiaEstaPassword_Local1!
